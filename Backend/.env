# Database connection settings (read by database/database.go).
# These must match the Postgres instance running on your machine.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Jesuslovesyou@11
DB_NAME=expense_tracker

# Secret used to sign JWTs (read by handlers when issuing login tokens).
# CHANGE THIS to a long, random string. Anyone who knows it can forge logins.
JWT_SECRET=change-me-to-a-long-random-secret

# Port the HTTP server listens on (optional; defaults to 8080).
PORT=8081
